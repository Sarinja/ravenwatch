{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RavenWatch",
  "version": "0.6.0",
  "identifier": "com.tauri.ravenwatch",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "RavenWatch",
        "width": 340,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://journeytoragnarok.com https://api.torn.com https://www.torn.com https://yata.yt https://ffscouter.com; img-src 'self' data: https:; media-src 'self' data: asset:; style-src 'self' 'unsafe-inline'; script-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../public/docs/readme.html": "docs/readme.html",
      "../public/docs/changelog.html": "docs/changelog.html"
    }
  }
}